# =============================================================================
# EvalIA — variables de entorno
# Producción: Vercel (app) + Railway (Postgres y/o mismo app)
# =============================================================================

# --- Postgres (Railway) ---
# Desde el plugin Postgres en Railway: copia DATABASE_URL (suele ser host *.rlwy.net).
# Ejemplo de forma (no uses credenciales reales en el repo):
DATABASE_URL="postgresql://USER:PASSWORD@HOST.railway.internal:PORT/railway?schema=public&sslmode=require"

# --- URL pública de la app (Vercel o dominio de Railway) ---
# Debe coincidir con la URL real del navegador, https://, sin barra final.
NEXT_PUBLIC_APP_URL="https://tu-proyecto.vercel.app"
NEXTAUTH_URL="https://tu-proyecto.vercel.app"

# Secreto de sesión (obligatorio en producción; si falta → error de configuración NextAuth)
# Generar: openssl rand -base64 32
AUTH_SECRET="pon-aqui-un-secreto-largo-aleatorio"

# Opcional: si tu panel solo ofrece el nombre antiguo, mismo valor que AUTH_SECRET:
# NEXTAUTH_SECRET="mismo-valor-que-AUTH_SECRET"

# --- Integraciones (cuando pruebes voz / evaluación) ---
ELEVENLABS_API_KEY=""
ELEVENLABS_AGENT_ID=""
ELEVENLABS_WEBHOOK_SECRET=""

OPENAI_API_KEY=""
# OPENAI_EVAL_MODEL="gpt-4o-mini"

# =============================================================================
# Solo desarrollo en tu Mac (pnpm dev)
# =============================================================================
# DATABASE_URL="postgresql://postgres:clave@localhost:5432/evalia?schema=public"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXTAUTH_URL="http://localhost:3000"
