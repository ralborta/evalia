# --- Local ---
# DATABASE_URL con usuario obligatorio:
# postgresql://USER:PASSWORD@localhost:5432/evalia?schema=public

# --- Vercel (Next.js) + Railway (Postgres) ---
# 1) Crea Postgres en Railway, copia "DATABASE_URL" (suele incluir ssl; si falla, añade ?sslmode=require).
# 2) En Vercel → Settings → Environment Variables (Production + Preview si aplica):
#    - DATABASE_URL          → la de Railway
#    - NEXTAUTH_URL          → https://TU-DOMINIO.vercel.app  (sin barra final)
#    - NEXT_PUBLIC_APP_URL   → misma URL pública (links de entrevista)
#    - AUTH_SECRET           → secreto largo y aleatorio
#    - ELEVENLABS_* y OPENAI_API_KEY
# 3) Webhook ElevenLabs → POST https://TU-DOMINIO.vercel.app/api/webhooks/elevenlabs/post-call
# 4) Tras el primer deploy: pnpm prisma migrate deploy (o db push solo si aceptas esquema sin migraciones formales)
#    desde CI o tu máquina apuntando al DATABASE_URL de producción.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/evalia?schema=public"

NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="genera-un-secreto-largo-aleatorio"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

ELEVENLABS_API_KEY=""
ELEVENLABS_AGENT_ID=""
ELEVENLABS_WEBHOOK_SECRET=""

OPENAI_API_KEY=""

# Opcional: modelo de evaluación (default gpt-4o-mini en código)
# OPENAI_EVAL_MODEL="gpt-4o-mini"
