# --- Local ---
# DATABASE_URL con usuario obligatorio:
# postgresql://USER:PASSWORD@localhost:5432/evalia?schema=public

# --- Vercel (Next.js) + Railway (Postgres) ---
# 1) Crea Postgres en Railway, copia "DATABASE_URL" (suele incluir ssl; si falla, añade ?sslmode=require).
# 2) Variables en Vercel o en el servicio web de Railway (Production):
#    - DATABASE_URL          → Postgres Railway
#    - AUTH_SECRET           → obligatorio (ej. openssl rand -base64 32)
#    - NEXTAUTH_URL          → https://tu-dominio (sin barra final)
#    - NEXT_PUBLIC_APP_URL   → misma URL pública
#    - ELEVENLABS_* y OPENAI_API_KEY (cuando pruebes voz / evaluación)
# 3) Webhook ElevenLabs → POST https://tu-dominio/api/webhooks/elevenlabs/post-call
# 4) Tras el primer deploy: prisma db push / migrate deploy contra el DATABASE_URL de producción.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/evalia?schema=public"

# --- Auth (obligatorio en producción; si falta → "Server error" de NextAuth) ---
# Genera uno: openssl rand -base64 32
AUTH_SECRET="genera-un-secreto-largo-aleatorio"
# Alternativa si tu plataforma solo permite el nombre antiguo:
# NEXTAUTH_SECRET="mismo-valor-que-AUTH_SECRET"

# URL canónica de la app (Auth.js / NextAuth). En Vercel/Railway usa tu URL pública https://...
NEXTAUTH_URL="http://localhost:3000"
# Si usas Auth.js v5 con AUTH_URL en tu host:
# AUTH_URL="http://localhost:3000"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

ELEVENLABS_API_KEY=""
ELEVENLABS_AGENT_ID=""
ELEVENLABS_WEBHOOK_SECRET=""

OPENAI_API_KEY=""

# Opcional: modelo de evaluación (default gpt-4o-mini en código)
# OPENAI_EVAL_MODEL="gpt-4o-mini"
